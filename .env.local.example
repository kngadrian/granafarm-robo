# OpenAI API Key — required for chat agents and AI supplier finder
OPENAI_API_KEY=your_openai_key

# Vercel KV — optional, used for caching AI-generated supplier lists (30 days)
# If not configured, the supplier API will still work without caching
KV_REST_API_URL=your_vercel_kv_url
KV_REST_API_TOKEN=your_vercel_kv_token
